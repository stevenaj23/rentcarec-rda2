generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SistemaExterno {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre    String?   @unique
  codigo    String?   @unique
  url       String?
  apiKey    String?   @map("api_key")
  isActive  Boolean?  @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("sistemas_externos")
}

model Mantenimiento {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vehiculoId  String?   @map("vehiculo_id") @db.Uuid
  tipo        String?
  descripcion String?
  fechaInicio DateTime? @map("fecha_inicio") @db.Timestamp(6)
  fechaFin    DateTime? @map("fecha_fin") @db.Timestamp(6)
  costo       Decimal?  @db.Decimal(10, 2)
  tecnico     String?
  isActive    Boolean?  @default(true) @map("is_active")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("mantenimientos")
}

model Kardex {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vehiculoId     String?   @map("vehiculo_id") @db.Uuid
  evento         String?
  estadoAnterior String?   @map("estado_anterior")
  estadoNuevo    String?   @map("estado_nuevo")
  usuarioId      String?   @map("usuario_id") @db.Uuid
  referencia     String?
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("kardex")
}
