# Compartida por todos los microservicios
DATABASE_URL="postgresql://user:password@host:5432/urbancar?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/urbancar"

# JWT — mismo secreto para que los tokens funcionen en todos los servicios
JWT_SECRET="your_super_secret_key_here"
JWT_EXPIRES_IN="7d"

# Entorno
NODE_ENV=production

# CORS — en producción usar la URL del frontend en Azure; en local usar *
CORS_ORIGIN=*

# RabbitMQ — Event Bus
# Local (docker-compose): amqp://rentcar:rentcar2024@localhost:5672/rentcar
# Producción: amqp://user:pass@host:5672/vhost
RABBITMQ_URL=amqp://rentcar:rentcar2024@localhost:5672/rentcar
RABBITMQ_EXCHANGE=rentcar.eventos
